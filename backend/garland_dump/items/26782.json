  "item": {
    "name": "Magicked Bed",
    "description": "This flying furnishing eliminates the need to get up in the morning─or ever. Modern magic put to good use at last!",
    "mount": {
      "name": "Magicked Bed",
      "action": "Summon forth your magicked bed, and dream a little dream of never needing to get up.",
      "description": "Once upon a time, in the Kingdom of Voeburt, there lived a member of the royal family slothful of body but quick of mind. This man desired naught more than to never be parted from his pillow, and so commissioned a bed that could fly...only to swiftly take to the sky without paying for it. He, presumably, lived happily ever after.",
      "tooltip": "Do not your mortal bodies tire?<br>Far better to dwell in dream.<br>   - Sri Lakshmi",
      "icon": 4152,
      "guideIcon": 68152
    },
